<div class="min-h-screen bg-slate-50 dark:bg-[#0D1B2A] px-6 py-10">
  <div class="max-w-5xl mx-auto">

    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Gerenciar ONGs</h1>
        <p class="text-sm text-slate-500 dark:text-white/50 mt-1">Aprovação e gestão de organizações cadastradas</p>
      </div>
    </div>

    {{#if sucesso}}
    <div class="flex items-center gap-3 bg-green-50 border border-green-200 text-green-700 p-4 rounded-xl mb-6 text-sm">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
      Ação realizada com sucesso.
    </div>
    {{/if}}

    {{#if ongs.length}}
    <div class="space-y-4">
      {{#each ongs}}
      <div class="bg-white dark:bg-[#1D3273]/20 border border-slate-200 dark:border-white/10 rounded-2xl p-5 shadow-sm">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
          <div class="flex-1">
            <div class="flex items-center gap-2 mb-2">
              {{#if isPendente}}
              <span class="px-2.5 py-1 rounded-full bg-yellow-100 text-yellow-700 text-xs font-semibold">Pendente</span>
              {{else if isAprovada}}
              <span class="px-2.5 py-1 rounded-full bg-green-100 text-green-700 text-xs font-semibold">Aprovada</span>
              {{else}}
              <span class="px-2.5 py-1 rounded-full bg-red-100 text-red-700 text-xs font-semibold">Rejeitada</span>
              {{/if}}
            </div>
            <h2 class="text-base font-bold text-slate-900 dark:text-white">{{nome}}</h2>
            <p class="text-sm text-slate-500 dark:text-white/50">{{email}} · {{cnpj}}</p>
            <p class="text-xs text-slate-400 dark:text-white/40 mt-1">{{area_atuacao}} · {{telefone}}</p>
            {{#if observacao_admin}}
            <p class="text-xs text-slate-500 dark:text-white/50 mt-2 italic">Obs: {{observacao_admin}}</p>
            {{/if}}
          </div>

          <div class="flex flex-col gap-2 shrink-0 min-w-[200px]">
            {{#unless isAprovada}}
            <form method="POST" action="/admin/ongs/{{id}}/aprovar" class="flex gap-2">
              <input type="text" name="observacao" placeholder="Observação (opcional)"
                class="flex-1 text-xs rounded-lg px-2 py-1.5 border border-slate-200 bg-white text-slate-700 focus:outline-none focus:ring-1 focus:ring-green-400" />
              <button type="submit"
                class="bg-green-600 hover:bg-green-700 text-white px-3 py-1.5 rounded-lg text-xs font-semibold transition whitespace-nowrap">
                Aprovar
              </button>
            </form>
            {{/unless}}
            {{#unless isRejeitada}}
            <form method="POST" action="/admin/ongs/{{id}}/rejeitar" class="flex gap-2">
              <input type="text" name="observacao" placeholder="Motivo (opcional)"
                class="flex-1 text-xs rounded-lg px-2 py-1.5 border border-slate-200 bg-white text-slate-700 focus:outline-none focus:ring-1 focus:ring-red-400" />
              <button type="submit"
                class="bg-red-600 hover:bg-red-700 text-white px-3 py-1.5 rounded-lg text-xs font-semibold transition whitespace-nowrap">
                Rejeitar
              </button>
            </form>
            {{/unless}}
          </div>
        </div>
      </div>
      {{/each}}
    </div>
    {{else}}
    <div class="text-center mt-20 opacity-60">Nenhuma ONG cadastrada.</div>
    {{/if}}

  </div>
</div>
