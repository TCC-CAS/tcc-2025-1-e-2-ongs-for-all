<section class="min-h-screen px-6 py-10">
  <div class="max-w-6xl mx-auto">

    <h1 class="text-3xl font-bold mb-4">
      {{#if nomeOngFiltrada}}
        Necessidades de {{nomeOngFiltrada}}
      {{else}}
        Necessidades das ONGs
      {{/if}}
    </h1>

    {{#if filtroOngId}}
    <div class="flex items-center gap-3 mb-6">
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#2D4BA6]/10 dark:bg-[#4886D9]/20 text-[#2D4BA6] dark:text-[#4886D9] text-sm font-semibold">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
        </svg>
        {{#if nomeOngFiltrada}}{{nomeOngFiltrada}}{{else}}ONG #{{filtroOngId}}{{/if}}
      </span>
      <a href="/necessidades"
        class="inline-flex items-center gap-1 px-3 py-2 rounded-full border border-slate-200 dark:border-white/10 text-sm font-medium text-slate-600 dark:text-white/70 hover:opacity-80 transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
        Ver todas
      </a>
    </div>
    {{/if}}

    {{#if necessidades.length}}

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

      {{#each necessidades}}

      <div class="bg-white dark:bg-[#1D3273]/20 border rounded-xl p-6 shadow">

        <h2 class="text-xl font-bold mb-2">
          {{titulo}}
        </h2>

        <p class="text-sm opacity-80 mb-3">
          ONG: {{nome_ong}}
        </p>

        <p class="text-sm mb-4">
          {{descricao}}
        </p>

        <div class="flex justify-between text-sm mb-2">
          <span class="font-semibold">Categoria:</span>
          <span>{{categoria}}</span>
        </div>

        <div class="flex justify-between text-sm mb-2">
          <span class="font-semibold">Meta:</span>
          <span>{{quantidade}}</span>
        </div>

        <div class="flex justify-between text-sm mb-2">
          <span class="font-semibold">Recebido:</span>
          <span>{{quantidade_recebida}}</span>
        </div>

        <div class="flex justify-between text-sm mb-4">
          <span class="font-semibold">Faltam:</span>
          <span>{{faltante}}</span>
        </div>

        <div class="mt-4">
          <div class="flex justify-between text-sm mb-1">
            <span class="font-semibold">Progresso</span>
            <span>{{percentual}}%</span>
          </div>

          <div class="w-full bg-slate-200 dark:bg-white/10 rounded-full h-3 overflow-hidden">
            <div class="bg-green-500 h-3 rounded-full transition-all duration-500" style="width: {{percentual}}%;">
            </div>
          </div>

          <p class="text-sm mt-2 opacity-80">
            {{quantidade_recebida}} de {{quantidade}} atendidos
          </p>
        </div>

        <a href="/necessidades/{{id}}"
          class="block text-center bg-blue-600 hover:bg-blue-700 text-white py-2 rounded-lg mt-5">
          Ver detalhes
        </a>

      </div>

      {{/each}}

    </div>

    {{else}}

    <div class="text-center mt-20 opacity-70">
      Nenhuma necessidade cadastrada ainda.
    </div>

    {{/if}}

  </div>
</section>