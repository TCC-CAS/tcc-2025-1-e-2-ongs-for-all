<section class="min-h-screen px-6 py-12 transition-colors duration-300 bg-white text-[#1D3273] dark:bg-[#0D1B2A] dark:text-white">
  <div class="max-w-7xl mx-auto space-y-8">

    <!-- Cabeçalho -->
    <div>
      <h1 class="text-3xl font-extrabold bg-gradient-to-r from-teal-400 to-blue-600 text-transparent bg-clip-text">
        Minhas Doações
      </h1>
      <p class="mt-1 text-[#1D3273]/70 dark:text-white/70 text-sm">
        Acompanhe todas as doações que você realizou
      </p>
    </div>

    <!-- Tabela -->
    <div class="bg-[#1D3273]/10 dark:bg-white/10 border border-[#1D3273]/20 dark:border-white/20 rounded-xl shadow-lg overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b border-[#1D3273]/20 dark:border-white/20">
              <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#1D3273]/50 dark:text-white/50">Data</th>
              <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#1D3273]/50 dark:text-white/50">Valor</th>
              <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#1D3273]/50 dark:text-white/50">Categoria</th>
              <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[#1D3273]/50 dark:text-white/50">ONG</th>
            </tr>
          </thead>
          <tbody>
            {{#each doacoes}}
            <tr class="border-b border-[#1D3273]/10 dark:border-white/10 hover:bg-[#1D3273]/5 dark:hover:bg-white/5 transition">
              <td class="px-6 py-4 text-sm whitespace-nowrap">{{this.data}}</td>
              <td class="px-6 py-4 text-sm font-semibold">R$ {{this.valor}}</td>
              <td class="px-6 py-4 text-sm">{{this.tipo}}</td>
              <td class="px-6 py-4 text-sm">{{this.nome_ong}}</td>
            </tr>
            {{/each}}
            {{#unless doacoes.length}}
            <tr>
              <td colspan="4" class="px-6 py-12 text-center text-[#1D3273]/50 dark:text-white/50">
                Você ainda não realizou nenhuma doação.
              </td>
            </tr>
            {{/unless}}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Ação rápida -->
    <div class="flex justify-end">
      <a href="/doacoes/nova"
        class="inline-flex items-center gap-2 px-6 py-2.5 rounded-xl bg-gradient-to-r from-green-400 to-blue-500 text-white font-semibold shadow hover:opacity-90 transition text-sm">
        Fazer uma doação
      </a>
    </div>

  </div>
</section>
