<section id="historico"
    class="min-h-screen px-6 py-12 bg-[#1D3273] text-white dark:bg-white dark:text-[#1D3273] transition-all">
    <div class="max-w-7xl mx-auto space-y-12">

        <div class="text-center">
            <h1 class="text-4xl font-bold mb-6">📋 Seu Histórico de Doações</h1>
            <p class="text-white/80 dark:text-[#1D3273]/80">Veja todas as doações realizadas 💙</p>
        </div>

        <div class="overflow-x-auto">
            <table
                class="min-w-full bg-white/10 dark:bg-[#F0F4F8] backdrop-blur-lg rounded-xl shadow-lg border border-white/20 dark:border-gray-300">
                <thead class="bg-white/20 dark:bg-[#D9E2EC]">
                    <tr>
                        <th class="px-6 py-3 text-left text-sm font-semibold uppercase">Data</th>
                        <th class="px-6 py-3 text-left text-sm font-semibold uppercase">Valor (R$)</th>
                        <th class="px-6 py-3 text-left text-sm font-semibold uppercase">Categoria</th>
                        <th class="px-6 py-3 text-left text-sm font-semibold uppercase">ONG</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each doacoes}}
                    <tr class="hover:bg-white/20 dark:hover:bg-gray-100">
                        <td class="px-6 py-4">{{this.data}}</td>
                        <td class="px-6 py-4">R$ {{this.valor}}</td>
                        <td class="px-6 py-4">{{this.tipo}}</td>
                        <td class="px-6 py-4">{{this.nome_ong}}</td>
                    </tr>
                    {{/each}}
                    {{#unless doacoes.length}}
                    <tr>
                        <td colspan="4" class="px-6 py-4 text-center text-gray-300 dark:text-gray-500">
                            Você ainda não realizou doações.
                        </td>
                    </tr>
                    {{/unless}}
                </tbody>
            </table>
        </div>

        <div class="flex justify-center pt-6">
            <a href="/dashboard"
                class="bg-gradient-to-r from-blue-600 to-pink-500 text-white px-6 py-3 rounded-full shadow hover:opacity-90 transition">
                Voltar para o Dashboard
            </a>
        </div>

    </div>
</section>