<div class="flex flex-col items-center justify-center min-h-screen py-10 px-4">
  <div class="w-full max-w-lg bg-white dark:bg-[#102235] rounded-2xl shadow-lg border border-slate-200 dark:border-white/10 p-8">

    <div class="text-center mb-8">
      <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-violet-500 to-purple-700 flex items-center justify-center mx-auto mb-4 shadow-md">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V19a4 4 0 00-4-4H9a4 4 0 00-4 4v2M12 11a4 4 0 100-8 4 4 0 000 8z" />
        </svg>
      </div>
      <h1 class="text-2xl font-bold text-[#2D4BA6] dark:text-white">Cadastro de Empresa Parceira</h1>
      <p class="text-sm text-slate-500 dark:text-white/50 mt-1">Junte-se à plataforma e apoie ONGs</p>
    </div>

    {{#if error}}
    <div class="mb-5 px-4 py-3 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-300 text-sm">
      {{error}}
    </div>
    {{/if}}

    <form method="POST" action="/register-empresa" class="space-y-4">

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Nome fantasia *</label>
          <input type="text" name="nome_fantasia" value="{{form.nome_fantasia}}" required maxlength="255"
            class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-violet-400" />
        </div>
        <div>
          <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Razão social</label>
          <input type="text" name="razao_social" value="{{form.razao_social}}" maxlength="255"
            class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-violet-400" />
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Email *</label>
          <input type="email" name="email" value="{{form.email}}" required
            class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-violet-400" />
        </div>
        <div>
          <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">CNPJ *</label>
          <input type="text" name="cnpj" value="{{form.cnpj}}" required maxlength="18" placeholder="00.000.000/0000-00"
            class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-violet-400" />
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Telefone</label>
          <input type="tel" name="telefone" value="{{form.telefone}}" maxlength="20"
            class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-violet-400" />
        </div>
        <div>
          <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Setor de atuação</label>
          <input type="text" name="setor" value="{{form.setor}}" maxlength="100" placeholder="Ex: Tecnologia, Saúde..."
            class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-violet-400" />
        </div>
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Descrição</label>
        <textarea name="descricao" rows="3" maxlength="1000" placeholder="Conte um pouco sobre sua empresa..."
          class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-violet-400 resize-none">{{form.descricao}}</textarea>
      </div>

      <div>
        <label class="block text-sm font-semibold text-slate-700 dark:text-white/80 mb-1">Senha *</label>
        <input type="password" name="senha" required minlength="6"
          class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-violet-400" />
      </div>

      <button type="submit"
        class="w-full py-3 rounded-2xl bg-gradient-to-r from-violet-500 to-purple-700 text-white font-bold text-sm shadow-md hover:opacity-90 transition mt-2">
        Criar conta corporativa
      </button>
    </form>

    <p class="text-center text-sm text-slate-500 dark:text-white/50 mt-5">
      Já tem conta?
      <a href="/login" class="text-violet-600 dark:text-violet-400 font-semibold hover:underline">Entrar</a>
    </p>
  </div>
</div>
