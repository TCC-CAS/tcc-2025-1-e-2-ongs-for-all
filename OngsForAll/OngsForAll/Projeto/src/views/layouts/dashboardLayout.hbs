<!DOCTYPE html>
<html lang="pt-br" class="bg-white text-gray-900 dark:bg-[#0D1B2A] dark:text-white">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{title}}{{#if stitle}} - {{stitle}}{{/if}}</title>

  <link rel="stylesheet" href="/public/dist/global.css" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body class="min-h-screen bg-[#F8FAFC] text-[#1D3273] dark:bg-[#0D1B2A] dark:text-white transition-colors duration-300">
  <div class="min-h-screen flex">

    {{#if naoLidas}}
    <span
      class="absolute -top-2 -right-2 min-w-[1.25rem] h-5 px-1 rounded-full bg-red-500 text-white text-[10px] font-bold flex items-center justify-center">
      {{naoLidas}}
    </span>
    {{/if}}
    </a>

    <!-- Sidebar usuário -->
    <aside
      class="hidden lg:flex w-72 flex-col bg-white border-r border-slate-200 dark:bg-[#102235] dark:border-white/10 shadow-sm">
      <div class="px-6 py-6 border-b border-slate-200 dark:border-white/10">
        <div class="flex items-center gap-3">
          <div
            class="w-12 h-12 rounded-2xl bg-gradient-to-br from-blue-500 to-teal-400 flex items-center justify-center text-white font-bold text-lg shadow-md">
            U
          </div>

          <div class="min-w-0">
            <h2 class="text-lg font-bold text-[#1D3273] dark:text-white truncate">
              Painel do Usuário
            </h2>
            <p class="text-sm text-slate-500 dark:text-white/60 truncate">
              {{#if user.nome}}{{user.nome}}{{else}}Área do usuário{{/if}}
            </p>
          </div>
        </div>
      </div>

      <nav class="p-4 flex flex-col h-full">
        <div class="space-y-2">
          <p class="px-3 text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40">
            Navegação
          </p>

          <a href="/dashboard"
            class="flex items-center gap-3 px-4 py-3 rounded-2xl bg-slate-100 hover:bg-slate-200 text-[#1D3273] dark:bg-white/10 dark:hover:bg-white/15 dark:text-white transition">
            <span class="text-lg">📊</span>
            <span class="font-medium">Dashboard</span>
          </a>

          <a href="/doacoes"
            class="flex items-center gap-3 px-4 py-3 rounded-2xl hover:bg-slate-100 text-[#1D3273] dark:hover:bg-white/10 dark:text-white transition">
            <span class="text-lg">📋</span>
            <span class="font-medium">Minhas doações</span>
          </a>

          <a href="/necessidades"
            class="flex items-center gap-3 px-4 py-3 rounded-2xl hover:bg-slate-100 text-[#1D3273] dark:hover:bg-white/10 dark:text-white transition">
            <span class="text-lg">📌</span>
            <span class="font-medium">Necessidades</span>
          </a>
        </div>

        <div class="mt-6">
          <p class="px-3 text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40">
            Ação rápida
          </p>

          <a href="/doacoes/nova"
            class="mt-2 flex items-center justify-center gap-2 px-4 py-3 rounded-2xl bg-gradient-to-r from-green-400 to-blue-500 text-white font-semibold shadow-md hover:opacity-90 transition">
            <span class="text-lg">💖</span>
            <span>Fazer uma doação</span>
          </a>
        </div>

        <div class="mt-6 space-y-2">
          <p class="px-3 text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-white/40">
            Conta
          </p>

          <a href="/perfil/editar"
            class="flex items-center gap-3 px-4 py-3 rounded-2xl hover:bg-slate-100 text-[#1D3273] dark:hover:bg-white/10 dark:text-white transition">
            <span class="text-lg">⚙️</span>
            <span class="font-medium">Perfil</span>
          </a>
        </div>

        <a href="/notificacoes"
          class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-100 text-[#1D3273] dark:hover:bg-white/10 dark:text-white transition">
          <span>🔔</span>
          <span class="font-medium">Notificações</span>
        </a>

        <div class="mt-auto pt-6">
          <a href="/logout"
            class="flex items-center justify-center gap-2 w-full px-4 py-3 rounded-2xl bg-red-500 text-white hover:bg-red-600 transition shadow-sm">
            <span>🚪</span>
            <span class="font-medium">Sair</span>
          </a>
        </div>
      </nav>
    </aside>

    <!-- Conteúdo -->
    <main class="flex-1 min-w-0 flex flex-col">

      <!-- Topbar -->
      <header
        class="sticky top-0 z-30 bg-white/90 dark:bg-[#0D1B2A]/90 backdrop-blur border-b border-slate-200 dark:border-white/10">
        <div class="px-4 sm:px-6 py-4 flex items-center justify-between gap-4">
          <div class="min-w-0">
            <h1 class="text-xl sm:text-2xl font-bold text-[#1D3273] dark:text-white truncate">
              {{#if title}}{{title}}{{else}}Dashboard{{/if}}
            </h1>
            <p class="text-sm text-slate-500 dark:text-white/60">
              Acompanhe suas doações e visualize seu impacto.
            </p>
          </div>

          <div class="flex items-center gap-3">
            <div class="hidden sm:flex items-center gap-3 px-3 py-2 rounded-2xl bg-slate-100 dark:bg-white/10">
              <div
                class="w-9 h-9 rounded-xl bg-gradient-to-br from-blue-500 to-teal-400 flex items-center justify-center text-white text-sm font-bold">
                {{#if user.nome}}{{user.nome.[0]}}{{else}}U{{/if}}
              </div>
              <div class="leading-tight">
                <p class="text-sm font-semibold text-[#1D3273] dark:text-white">
                  {{#if user.nome}}{{user.nome}}{{else}}Usuário{{/if}}
                </p>
                <p class="text-xs text-slate-500 dark:text-white/60">
                  Conta pessoal
                </p>
              </div>
            </div>

            <a href="/notificacoes"
              class="relative flex items-center justify-center w-10 h-10 rounded-2xl bg-slate-100 dark:bg-white/10 hover:opacity-90 shadow-sm transition"
              title="Notificações">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#1D3273] dark:text-white" fill="none"
                viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6 6 0 10-12 0v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
              </svg>
              {{#if naoLidas}}
              <span
                class="absolute -top-1 -right-1 min-w-[1.1rem] h-[1.1rem] px-1 rounded-full bg-red-500 text-white text-[10px] font-bold flex items-center justify-center">
                {{naoLidas}}
              </span>
              {{/if}}
            </a>

            <button id="toggle-theme" type="button"
              class="flex items-center justify-center w-10 h-10 rounded-2xl bg-[#1D3273] text-white dark:bg-white dark:text-[#1D3273] hover:opacity-90 shadow-sm transition">
              <!-- Lua -->
              <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24"
                stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
              </svg>

              <!-- Sol -->
              <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden" fill="none"
                viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M12 3v2m0 14v2m9-9h-2M5 12H3m15.364 6.364l-1.414-1.414M6.05 6.05 4.636 4.636m12.728 0l-1.414 1.414M6.05 17.95l-1.414 1.414M12 8a4 4 0 100 8 4 4 0 000-8z" />
              </svg>
            </button>
          </div>
        </div>
      </header>

      <!-- Atalhos mobile -->
      <div class="lg:hidden px-4 sm:px-6 pt-4">
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          <a href="/dashboard"
            class="px-4 py-3 rounded-2xl bg-white dark:bg-white/10 border border-slate-200 dark:border-white/10 shadow-sm text-sm font-medium text-center">
            📊 Dashboard
          </a>
          <a href="/doacoes"
            class="px-4 py-3 rounded-2xl bg-white dark:bg-white/10 border border-slate-200 dark:border-white/10 shadow-sm text-sm font-medium text-center">
            📋 Doações
          </a>
          <a href="/necessidades"
            class="px-4 py-3 rounded-2xl bg-white dark:bg-white/10 border border-slate-200 dark:border-white/10 shadow-sm text-sm font-medium text-center">
            📌 Necessidades
          </a>
        </div>
      </div>

      <!-- Conteúdo da página -->
      <div class="flex-1 px-4 sm:px-6 py-6">
        {{{body}}}
      </div>
    </main>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const html = document.documentElement;
      const toggle = document.getElementById('toggle-theme');
      const iconMoon = document.getElementById('icon-moon');
      const iconSun = document.getElementById('icon-sun');

      function updateIcon(theme) {
        if (!iconMoon || !iconSun) return;

        if (theme === 'dark') {
          iconMoon.classList.add('hidden');
          iconSun.classList.remove('hidden');
        } else {
          iconMoon.classList.remove('hidden');
          iconSun.classList.add('hidden');
        }
      }

      function applyTheme(theme) {
        if (theme === 'dark') html.classList.add('dark');
        else html.classList.remove('dark');

        localStorage.setItem('theme', theme);
        updateIcon(theme);
      }

      const saved = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      applyTheme(saved || (prefersDark ? 'dark' : 'light'));

      if (toggle) {
        toggle.addEventListener('click', () => {
          const next = html.classList.contains('dark') ? 'light' : 'dark';
          applyTheme(next);
          window.dispatchEvent(new Event('theme:changed'));
        });
      }
    });
  </script>
</body>

</html>