<!DOCTYPE html>
<html lang="pt-br" class="bg-white text-gray-900 dark:bg-[#0D1B2A] dark:text-white">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{title}}{{#if stitle}} - {{stitle}}{{/if}}</title>

  <link rel="stylesheet" href="/public/dist/global.css" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body class="min-h-screen bg-[#F8FAFC] text-[#1D3273] dark:bg-[#0D1B2A] dark:text-white transition-colors duration-300">

  <div class="min-h-screen flex">

    <!-- SIDEBAR ONG -->
    <aside
      class="w-72 bg-white border-r border-slate-200 dark:bg-[#102235] dark:border-white/10 shadow-sm flex flex-col">

      <!-- Logo / ONG -->
      <div class="p-6 border-b border-slate-200 dark:border-white/10">
        <div class="flex items-center gap-3">
          <div
            class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-teal-400 flex items-center justify-center text-white font-bold text-lg shadow">
            ONG
          </div>

          <div>
            <h2 class="text-lg font-bold text-[#1D3273] dark:text-white">
              Painel da ONG
            </h2>

            <p class="text-sm text-slate-500 dark:text-white/60">
              {{#if user.nome}}{{user.nome}}{{else}}Gestão institucional{{/if}}
            </p>
          </div>
        </div>
      </div>

      <!-- Menu -->
      <nav class="p-4 space-y-2 flex-1">

        <a href="/dashboard/ong"
          class="flex items-center gap-3 px-4 py-3 rounded-xl bg-slate-100 hover:bg-slate-200 text-[#1D3273] dark:bg-white/10 dark:hover:bg-white/15 dark:text-white transition">
          <span>📊</span>
          <span class="font-medium">Dashboard</span>
        </a>

        <a href="/ong/necessidades"
          class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-100 text-[#1D3273] dark:hover:bg-white/10 dark:text-white transition">
          <span>📌</span>
          <span class="font-medium">Minhas necessidades</span>
        </a>

        <a href="/necessidades/nova"
          class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-100 text-[#1D3273] dark:hover:bg-white/10 dark:text-white transition">
          <span>➕</span>
          <span class="font-medium">Nova necessidade</span>
        </a>

        <a href="/ong/interesses"
          class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-100 text-[#1D3273] dark:hover:bg-white/10 dark:text-white transition">
          <span>📦</span>
          <span class="font-medium">Interesses recebidos</span>
        </a>

        <a href="/perfil/editar"
          class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-100 text-[#1D3273] dark:hover:bg-white/10 dark:text-white transition">
          <span>⚙️</span>
          <span class="font-medium">Perfil</span>
        </a>

        <a href="/notificacoes"
          class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-slate-100 text-[#1D3273] dark:hover:bg-white/10 dark:text-white transition">
          <span>🔔</span>
          <span class="font-medium">Notificações</span>
        </a>

      </nav>

      <!-- Logout -->
      <div class="p-4 border-t border-slate-200 dark:border-white/10">
        <a href="/logout"
          class="flex items-center justify-center gap-2 w-full px-4 py-3 rounded-xl bg-red-500 text-white hover:bg-red-600 transition">
          <span>🚪</span>
          <span class="font-medium">Sair</span>
        </a>
      </div>

    </aside>

    <!-- CONTEÚDO -->
    <main class="flex-1 min-w-0 flex flex-col">

      <!-- TOPBAR -->
      <header
        class="sticky top-0 z-30 bg-white/90 dark:bg-[#0D1B2A]/90 backdrop-blur border-b border-slate-200 dark:border-white/10">
        <div class="px-6 py-4 flex items-center justify-between gap-4">

          <div>
            <h1 class="text-xl font-bold text-[#1D3273] dark:text-white">
              {{#if title}}{{title}}{{else}}Dashboard da ONG{{/if}}
            </h1>

            <p class="text-sm text-slate-500 dark:text-white/60">
              Gerencie suas necessidades e acompanhe as doações recebidas.
            </p>
          </div>

          <div class="flex items-center gap-2">
            <!-- Sino de notificações -->
            <a href="/notificacoes"
              class="relative flex items-center justify-center w-10 h-10 rounded-xl bg-slate-100 dark:bg-white/10 hover:opacity-90 shadow transition"
              title="Notificações">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#1D3273] dark:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6 6 0 10-12 0v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
              </svg>
              {{#if naoLidas}}
              <span class="absolute -top-1 -right-1 min-w-[1.1rem] h-[1.1rem] px-1 rounded-full bg-red-500 text-white text-[10px] font-bold flex items-center justify-center">
                {{naoLidas}}
              </span>
              {{/if}}
            </a>

            <!-- Tema -->
            <button id="toggle-theme"
            class="flex items-center justify-center w-10 h-10 rounded-xl bg-[#1D3273] text-white dark:bg-white dark:text-[#1D3273] shadow hover:opacity-90 transition">
            <!-- Lua -->
            <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24"
              stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12.79A9 9 0 1111.21 3
      7 7 0 0021 12.79z" />
            </svg>

            <!-- Sol -->
            <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24"
              stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v2m0 14v2m9-9h-2M5 12H3
      m15.364 6.364l-1.414-1.414M6.05 6.05
      4.636 4.636m12.728 0l-1.414 1.414
      M6.05 17.95l-1.414 1.414
      M12 8a4 4 0 100 8 4 4 0 000-8z" />
            </svg>
            </button>
          </div>

        </div>
      </header>

      <!-- PÁGINA -->
      <div class="px-6 py-6 flex-1">
        {{{body}}}
      </div>

    </main>

  </div>


  <!-- Script tema -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {

      const html = document.documentElement
      const toggle = document.getElementById('toggle-theme')

      const iconMoon = document.getElementById('icon-moon')
      const iconSun = document.getElementById('icon-sun')

      function updateIcon(theme) {
        if (theme === 'dark') {
          iconMoon.classList.add('hidden')
          iconSun.classList.remove('hidden')
        } else {
          iconMoon.classList.remove('hidden')
          iconSun.classList.add('hidden')
        }
      }

      function applyTheme(theme) {
        if (theme === 'dark') {
          html.classList.add('dark')
        } else {
          html.classList.remove('dark')
        }

        localStorage.setItem('theme', theme)
        updateIcon(theme)
      }

      const saved = localStorage.getItem('theme')
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches

      const theme = saved || (prefersDark ? 'dark' : 'light')

      applyTheme(theme)

      toggle.addEventListener('click', () => {
        const next = html.classList.contains('dark') ? 'light' : 'dark'
        applyTheme(next)

        // dispara evento para gráficos
        window.dispatchEvent(new Event('theme:changed'))
      })

    })
  </script>

</body>

</html>